$TTL 5 ; use a very short TTL for sped up keyset rolls
example.test.   IN SOA ns1.example.test. mail.example.test. (
                      2          ; serial
                     60          ; refresh (60 seconds)
                     60          ; retry (60 seconds)
                   3600          ; expire (1 hour)
                      5          ; minimum (5 seconds)
                    )
@           ZONEMD  2 1 2 d0c203b291a34bbd6cd6ba3210cf63aa4770b33d46e3a470553dc746a9c336de12d25760932ca0ee92c99154bdcaea87088ec28fba75202cb40d516472597ffc
@           NS  example.test.
@           NS  ns1.example.test.
@           A   127.0.0.1
ns1         A   127.0.0.1

; Define an in-memory zone to be served by the server. The zone is large
; enough that it cannot be fit into a single TCP AXFR response and so must
; be split by the server across multiple responses.
$ORIGIN example.test.
